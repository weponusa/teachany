          "id": "chn-m-erta-stories",
          "name": "《朝花夕拾》",
          "grade": 7,
          "prerequisites": [
            "chn-m-whole-book-reading"
          ],
          "extends": [],
          "parallel": [],
          "courses": [
            "chinese-erta-stories"
          ],
          "status": "active",
          "curriculum_standards": {
            "source": "《义务教育语文课程标准（2022年版）》第四学段（7~9年级）· 整本书阅读",
            "content_requirements": [
              "独立阅读《朝花夕拾》，这是鲁迅唯一的回忆散文集，属于第四学段整本书阅读推荐书目（7年级上学期）",
              "根据阅读进度完成读书笔记，针对作品的语言、形象、主题等方面的话题展开研讨",
              "借助多种媒介讲述、推荐《朝花夕拾》，说明推荐理由",
              "尝试改写《朝花夕拾》中的精彩片段",
              "结合自己的阅读体会，尝试撰写文学鉴赏文章"
            ],
            "teaching_tips": [
              "通读整书，了解主要内容，关注整体与局部的关系",
              "重视序言、目录在整本书阅读中的作用",
              "设计多样的语文实践活动：师生共读、朗诵会、故事会",
              "采用读书笔记、读书报告会、读书分享会等方式评价"
            ],
            "core_competencies": {
              "文化自信": "感受鲁迅的爱国情怀和民族精神，体会其对中华文化的深刻反思与批判性继承",
              "语言运用": "品味鲁迅散文的语言风格——犀利中带温情、幽默中含批判的白话文典范",
              "思维能力": "分析十篇散文（《狗·猫·鼠》《阿长与山海经》《二十四孝图》等）的结构、手法和主题联系",
              "审美创造": "鉴赏回忆性散文的艺术美，理解'朝花夕拾'的审美意境"
            }
          }
        },
