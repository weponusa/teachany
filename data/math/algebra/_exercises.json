  {
    "id": "ex-expr-001",
    "node_id": "algebraic-expressions",
    "bloom_level": "apply",
    "difficulty": 2,
    "type": "single_choice",
    "stem": "因式分解：x²-9 = ?",
    "options": [
      {
        "label": "A",
        "text": "(x+3)(x-3)",
        "correct": true
      },
      {
        "label": "B",
        "text": "(x-3)²",
        "correct": false
      },
      {
        "label": "C",
        "text": "(x+9)(x-1)",
        "correct": false
      },
      {
        "label": "D",
        "text": "x(x-9)",
        "correct": false
      }
    ],
    "feedback_correct": "对！x²-9=x²-3²=(x+3)(x-3)，用的是平方差公式a²-b²=(a+b)(a-b)。",
    "feedback_wrong": {
      "B": "(x-3)²=x²-6x+9，不等于x²-9。这里没有中间项-6x。",
      "C": "展开(x+9)(x-1)=x²+8x-9，不等于x²-9。",
      "D": "展开x(x-9)=x²-9x，不等于x²-9。x²-9不能提公因式x。"
    },
    "source": "原创",
    "tags": [
      "整式",
      "因式分解",
      "平方差公式"
    ]
  },
  {
    "id": "ex-expr-002",
    "node_id": "algebraic-expressions",
    "bloom_level": "evaluate",
    "difficulty": 4,
    "type": "single_choice",
    "stem": "小明说(a+b)²=a²+b²，他对吗？",
    "options": [
      {
        "label": "A",
        "text": "不对，正确的是(a+b)²=a²+2ab+b²",
        "correct": true
      },
      {
        "label": "B",
        "text": "对的，两项各自平方就行",
        "correct": false,
        "error_id": "err-square-formula"
      },
      {
        "label": "C",
        "text": "不对，应该是(a+b)²=a²-b²",
        "correct": false
      },
      {
        "label": "D",
        "text": "不对，应该是(a+b)²=2a²+2b²",
        "correct": false
      }
    ],
    "feedback_correct": "对！(a+b)²=a²+2ab+b²，不能漏掉中间的2ab。这是最常见的公式错误！",
    "feedback_wrong": {
      "B": "(a+b)²=(a+b)(a+b)=a²+ab+ba+b²=a²+2ab+b²，中间有2ab！",
      "C": "a²-b²=(a+b)(a-b)是平方差公式，不是完全平方公式。",
      "D": "展开是a²+2ab+b²，不是2a²+2b²。"
    },
    "source": "原创",
    "tags": [
      "整式",
      "完全平方公式",
      "纠错"
    ]
  },
