   "options": [
     {"label": "A", "text": "1", "is_correct": false},
     {"label": "B", "text": "2", "is_correct": true},
     {"label": "C", "text": "√2", "is_correct": false},
     {"label": "D", "text": "无最小值", "is_correct": false}
   ], "answer": "B",
   "feedback_correct": "正确！由基本不等式x+1/x≥2√(x·1/x)=2，当x=1/x即x=1时取等，最小值为2。",
   "feedback_wrong": {"A": "基本不等式给出下界是2不是1。", "C": "√2≈1.414，当x=1时f(1)=2>√2，最小值是2。", "D": "x>0时x+1/x有最小值2，在x=1处取到。"},
   "source": "教材同步", "tags": ["基本不等式", "最值"]},
  {"id": "ex-solidgeom-1", "node_id": "solid-geometry", "bloom_level": "understand", "difficulty": 3,
