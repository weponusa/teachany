     {"label": "B", "text": "直线垂直于面内两条相交直线", "is_correct": true},
     {"label": "C", "text": "直线垂直于面内两条平行直线", "is_correct": false},
     {"label": "D", "text": "直线垂直于面内所有直线", "is_correct": false}
