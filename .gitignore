# ============================================
# TeachAny Opensource .gitignore
# ============================================

# === OS ===
.DS_Store
Thumbs.db

# === IDE ===
.vscode/
.idea/
*.swp
*.swo

# === Node ===
node_modules/
package-lock.json

# === Build Artifacts ===
dist/
build/
*.min.js
*.min.css
output/

# === Admin skill (local only) ===
admin-skillhub-package/

# === Archive (too large for Git) ===
archive/

# === Python 环境 ===
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# === Registry 备份文件 ===
registry-backup-*.json
registry.json.backup.*
courseware-registry-backup-*.json
registry_backup_*.json
registry_fixed.json

# === 知识树备份（清污脚本产生） ===
data/trees/_backup_*/

# === 通用备份文件 ===
*.backup
*.backup-*
*.broken_backup

# === 临时验证脚本 ===
quick-verify.py
verify-*.py
verify_*.py
check-*.sh
verify-*.sh

# === 诊断/报告 JSON ===
quality-check-report.json
*-report.json
*_report.json

# === 测试/调试 HTML ===
test-*.html
test.html
debug.html
verify-*.html
清除缓存.html
知识图谱链接诊断.html
诊断*.html

# === 一次性报告 .md（保留核心文档） ===
ARCHITECTURE_REFACTOR_PLAN.md
ARCHIVE_README.md
COMMUNITY_INTEGRATION_VERIFICATION_REPORT.md
COMPOUND_VOWEL_RESTORATION_REPORT.md
COURSEWARE_COMPLETENESS_REPORT.md
DEPLOYMENT_FIX_REPORT.md
DEPLOYMENT_V6_SUCCESS.md
GitHub_Pages切换指南.md
GitHub_Pages部署成功报告.md
Git提交完成报告*.md
KNOWLEDGE_POINT_INDEX_SYSTEM.md
METADATA_CHECK_REPORT.md
MISSING_COURSEWARE_REPORT.md
PHASE_C_COMPLETION_REPORT.md
QUALITY_CHECK_REPORT.md
REFACTOR_COMPLETION_REPORT.md
SKILL_CN_V6_UPDATE.md
STATS_AND_PATH_GUIDE.md
TAG_SYSTEM_COMPLETE_REPORT.md
TTS引擎切换说明.md
分享海报文案.md
切换到GitHub_Actions部署指南.md
国内教师安装方案.md
课件打包方案.md
脚本功能总结.md

# === data/ 下的一次性文件 ===
data/DATA_CATALOG.md
data/DATA_DOWNLOAD_LOG.md
data/DEM_PRIORITY_NOTICE.md
data/FINAL_SUMMARY.md
data/MAP_RESOURCES_SUMMARY.md
data/QUICK_REFERENCE.md
data/TERRAIN_COMPARISON.md
data/TERRAIN_DOWNLOAD_GUIDE.md
data/TERRAIN_HYBRID_SOLUTION.md
data/TERRAIN_QUICK_START.md
data/TERRAIN_TILES_CONFIG.md
data/README_TERRAIN.md
data/textbook-supplements/EXTRACTION_GUIDE.md
data/textbook-supplements/FINAL_SUMMARY.md
data/history/DYNASTIES_CATALOG.md

# === data/ 下的一次性脚本 ===
data/analyze_dynasties.py
data/download_terrain_tiles.py
data/process_china_data.py
data/show_data_stats.py

# === 日志 ===
*.log
.env

# === v5.34.8 管理员发布权限标记（仅仓库 owner 本地创建，禁止入库） ===
.teachany-admin

# === v5.34.8 用户本地草稿（默认仅本地，不贡献到官方仓） ===
# 忽略 drafts 下所有"课件目录"（*/*），但放行目录本身和根级文件
community/drafts/*/
# 但 README 和 .gitkeep 需要入库，方便用户看到说明（不会被上面 */ 规则影响）
